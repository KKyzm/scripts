#!/usr/bin/env bash
set -euo pipefail

if ! command -v gum >/dev/null 2>&1; then
  echo "gum is required but not installed." >&2
  echo "Install (macOS): brew install gum" >&2
  echo "For other platforms, see: https://github.com/charmbracelet/gum" >&2
  exit 1
fi

if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  echo "Not a git repository." >&2
  exit 1
fi

entries=()
while IFS= read -r line; do
  entries+=("$line")
done < <(git remote -v | awk '$3=="(fetch)" {print $1 "\t" $2}' | awk '!seen[$0]++')

max_name_len=0
for entry in "${entries[@]}"; do
  name="${entry%%$'\t'*}"
  if (( ${#name} > max_name_len )); then
    max_name_len=${#name}
  fi
done

display_entries=()
for entry in "${entries[@]}"; do
  name="${entry%%$'\t'*}"
  url="${entry#*$'\t'}"
  pad=$((max_name_len - ${#name}))
  printf -v display "%s%*s  %s" "$name" "$pad" "" "$url"
  display_entries+=("$display")
done

if [[ ${#entries[@]} -eq 0 ]]; then
  echo "No git remotes found." >&2
  exit 1
fi

selected=""
if [[ ${#entries[@]} -eq 1 ]]; then
  selected_entry="${entries[0]}"
else
  selected_display=$(printf '%s\n' "${display_entries[@]}" | gum choose --header "Select a remote to open") || {
    echo "Canceled." >&2
    exit 1
  }
  selected_entry=""
  for i in "${!display_entries[@]}"; do
    if [[ "${display_entries[$i]}" == "$selected_display" ]]; then
      selected_entry="${entries[$i]}"
      break
    fi
  done
  if [[ -z "$selected_entry" ]]; then
    echo "Failed to map selection." >&2
    exit 1
  fi
fi

remote_name="${selected_entry%%$'\t'*}"
remote_url="${selected_entry#*$'\t'}"

if [[ -z "$remote_name" || -z "$remote_url" ]]; then
  echo "Failed to parse selection." >&2
  exit 1
fi

normalize_url() {
  local url="$1"

  if [[ "$url" =~ ^https?:// ]]; then
    echo "${url%.git}"
    return 0
  fi

  if [[ "$url" =~ ^git@([^:]+):(.+)$ ]]; then
    local host="${BASH_REMATCH[1]}"
    local path="${BASH_REMATCH[2]}"
    path="${path%.git}"
    echo "https://${host}/${path}"
    return 0
  fi

  if [[ "$url" =~ ^ssh:// ]]; then
    echo "Unsupported URL scheme: ssh://" >&2
    return 2
  fi

  echo "Unsupported URL format: $url" >&2
  return 2
}

open_url() {
  local url="$1"
  case "$(uname -s)" in
    Darwin)
      open "$url"
      ;;
    Linux)
      xdg-open "$url"
      ;;
    MINGW*|MSYS*|CYGWIN*)
      cmd.exe /c start "" "$url"
      ;;
    *)
      echo "Unsupported platform: $(uname -s)" >&2
      return 3
      ;;
  esac
}

final_url=$(normalize_url "$remote_url")
echo "Opening $final_url (from $remote_name)..."
open_url "$final_url"
